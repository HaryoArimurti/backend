{
  "openapi": "3.0.0",
  "info": { "title": "Backend API", "version": "1.0.0" },
  "servers": [{ "url": "http://localhost/backend" }],
  "paths": {
    "/register_api.php": {
      "post": {
        "summary": "Register User",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nama": { "type": "string", "example": "Haryo" },
                  "email": { "type": "string", "example": "haryo@gmail.com" },
                  "password": { "type": "string", "example": "12345" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/get_user.php": {
      "get": {
        "summary": "Get All Users",
        "responses": {
          "200": {
            "description": "Berhasil",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "nama": { "type": "string", "example": "Zaskia" },
                          "email": { "type": "string", "example": "zas@gmail.com" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/update_user.php": {
      "post": {
        "summary": "Edit User",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id_user": { "type": "integer", "example": 1 },
                  "nama": { "type": "string", "example": "Haryo Update" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "User updated" } }
      }
    },
    "/delete_user.php": {
      "post": {
        "summary": "Hapus User",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id_user": { "type": "integer", "example": 1 }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "User deleted" } }
      }
    }
  }
}